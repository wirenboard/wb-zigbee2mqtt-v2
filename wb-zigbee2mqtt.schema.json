{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "type": "object",
    "title": "WB Zigbee2MQTT Bridge",
    "configFile": {
        "path": "/mnt/data/etc/wb-zigbee2mqtt.conf",
        "service": "wb-zigbee2mqtt"
    },
    "properties": {
        "broker_url": {
            "title": "MQTT Broker URL",
            "type": "string",
            "default": "unix:///var/run/mosquitto/mosquitto.sock"
        },
        "zigbee2mqtt_base_topic": {
            "title": "Zigbee2MQTT base topic",
            "type": "string",
            "default": "zigbee2mqtt"
        },
        "device_id": {
            "title": "WB device ID",
            "type": "string",
            "default": "zigbee2mqtt"
        },
        "device_name": {
            "title": "WB device name",
            "type": "string",
            "default": "Zigbee2MQTT"
        }
    },
    "required": ["broker_url", "zigbee2mqtt_base_topic"],
    "translations": {
        "ru": {
            "WB Zigbee2MQTT Bridge": "Мост Zigbee2MQTT для Wiren Board",
            "MQTT Broker URL": "URL MQTT-брокера",
            "Zigbee2MQTT base topic": "Базовый топик Zigbee2MQTT",
            "WB device ID": "ID устройства в WB",
            "WB device name": "Имя устройства в WB"
        }
    }
}
